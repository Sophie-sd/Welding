# Django (Docker production on DigitalOcean)
DJANGO_SETTINGS_MODULE=config.settings.docker
SECRET_KEY=change-me-in-production-use-50-plus-random-chars
DEBUG=False

# Droplet IP (167.71.132.232), compose DNS "web", localhost for healthchecks
ALLOWED_HOSTS=khodakmetal.com,www.khodakmetal.com,167.71.132.232,127.0.0.1,localhost,web
CSRF_TRUSTED_ORIGINS=https://khodakmetal.com,https://www.khodakmetal.com

# Before SSL: USE_HTTPS=false
# After certbot: USE_HTTPS=true
USE_HTTPS=false
SITE_URL=https://khodakmetal.com

# PostgreSQL (Docker service "db")
POSTGRES_DB=weldingproject
POSTGRES_USER=weldingproject
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://weldingproject:change-me-strong-password@db:5432/weldingproject

# Email (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=khodakmetalsolution@gmail.com
EMAIL_HOST_PASSWORD=change-me-gmail-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@khodakmetal.com
QUOTE_NOTIFICATION_EMAIL=khodakmetalsolution@gmail.com

# Security (TLS at nginx; SECURE_SSL_REDIRECT=False in docker settings)
SECURE_HSTS_SECONDS=31536000

HTTP_PORT=80
