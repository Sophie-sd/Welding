# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-in-production-use-50-plus-random-chars
DEBUG=False
ALLOWED_HOSTS=khodakmetal.co.uk,www.khodakmetal.co.uk
CSRF_TRUSTED_ORIGINS=https://khodakmetal.co.uk,https://www.khodakmetal.co.uk

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@host:25060/dbname?sslmode=require

# Email (SMTP required in production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@khodakmetal.co.uk
QUOTE_NOTIFICATION_EMAIL=khodakmetalsolution@gmail.com

# Security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
