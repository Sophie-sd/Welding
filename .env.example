# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-in-production-use-50-plus-random-chars
DEBUG=False
ALLOWED_HOSTS=khodakmetal.com,www.khodakmetal.com
CSRF_TRUSTED_ORIGINS=https://khodakmetal.com,https://www.khodakmetal.com

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# Docker / managed PostgreSQL:
# POSTGRES_DB=weldingproject
# POSTGRES_USER=weldingproject
# POSTGRES_PASSWORD=strong-password
# DATABASE_URL=postgres://weldingproject:strong-password@db:5432/weldingproject

# Email (SMTP required in production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=khodakmetalsolution@gmail.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@khodakmetal.com
QUOTE_NOTIFICATION_EMAIL=khodakmetalsolution@gmail.com

# Security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
